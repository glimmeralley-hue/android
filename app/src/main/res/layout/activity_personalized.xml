<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/inputContainerRoutine"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.03"
                    android:text="Routine AI"
                    android:textColor="#FFFFFF"
                    android:textSize="42sp" />

                <View
                    android:id="@+id/auraPulseRoutine"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_toEndOf="@id/tvTitle"
                    android:layout_alignTop="@id/tvTitle"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="8dp"
                    android:background="@android:drawable/presence_online"
                    android:backgroundTint="#00FF00"
                    android:visibility="gone" />

            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:fontFamily="sans-serif-light"
                android:text="Your evolving fitness architect."
                android:textColor="#8E8E93"
                android:textSize="16sp" />

            <!-- AI Routine Area -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvChatRoutine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </ScrollView>

    <!-- Snowflake Loading (Centered overlay) -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:id="@+id/snowflakeLoader"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateDrawable="@android:drawable/ic_menu_rotate"
            app:tint="#FFFFFF"/>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/inputContainerRoutine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="16dp"
        android:background="#11FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/btnMicRoutine"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_btn_speak_now"
                android:padding="12dp"
                app:tint="#FFFFFF"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/etMessageInputRoutine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Update your goals or ask for a routine..."
                android:textColorHint="#8E8E93"
                android:textColor="#FFFFFF"
                android:background="@android:color/transparent"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp"
                android:maxLines="4"
                android:fontFamily="sans-serif-light"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnSendRoutine"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_send"
                android:padding="12dp"
                app:tint="#000000"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</RelativeLayout>
