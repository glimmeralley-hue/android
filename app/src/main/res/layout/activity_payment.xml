<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#000000"> <androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="12dp"
    android:backgroundTint="#1A1A1A"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checkout"
        android:textColor="#39FF14"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="15dp" />

    <ImageView
        android:id="@+id/imgProduct"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        android:background="#333333" />

    <TextView
        android:id="@+id/txtProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Product Name"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold|italic"
        android:layout_marginTop="15dp" />

    <TextView
        android:id="@+id/txtProductCost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kes 0.00"
        android:textColor="#39FF14"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etPaymentPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:hint="M-Pesa Number"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:inputType="phone"
        android:backgroundTint="#39FF14" />

    <Button
        android:id="@+id/btnSubmitPayment"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="25dp"
        android:text="Pay with M-Pesa"
        android:textColor="#000000"
        android:textStyle="bold"
        android:backgroundTint="#39FF14"
        app:cornerRadius="12dp" />

</LinearLayout>
</androidx.cardview.widget.CardView>
</LinearLayout>
