<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Identity"
                android:textColor="#FFFFFF"
                android:textSize="42sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="-0.03" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btnSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_manage"
                    app:tint="#FFFFFF" />
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/profileImageContainer"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:layout_marginBottom="40dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="70dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgProfileFull"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#44FFFFFF" />
        </androidx.cardview.widget.CardView>

        <!-- Biological Data Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BIOLOGICAL DATA"
            android:textColor="#8E8E93"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/editAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Chronological Age"
                    android:textColorHint="#48484A"
                    android:textColor="#FFFFFF"
                    android:background="@android:color/transparent"
                    android:inputType="number"
                    android:fontFamily="sans-serif-light"
                    android:padding="12dp"/>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#22FFFFFF" android:layout_marginHorizontal="8dp"/>

                <EditText
                    android:id="@+id/editGoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Primary Evolution Goal"
                    android:textColorHint="#48484A"
                    android:textColor="#FFFFFF"
                    android:background="@android:color/transparent"
                    android:fontFamily="sans-serif-light"
                    android:padding="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Clinical Context Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLINICAL CONTEXT"
            android:textColor="#8E8E93"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="12dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/editMedicalHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Medical history / Limitations"
                android:textColorHint="#48484A"
                android:textColor="#FFFFFF"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif-light"
                android:padding="16dp"
                android:minLines="4"
                android:gravity="top"/>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="#FFFFFF"
            android:text="Update Identity"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:fontFamily="sans-serif-medium"
            android:textSize="17sp"
            app:cornerRadius="32dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="#1C1C1E"
            android:text="Sever Connection"
            android:textAllCaps="false"
            android:textColor="#FF453A"
            android:fontFamily="sans-serif-light"
            app:cornerRadius="32dp"
            android:layout_marginBottom="40dp"/>

    </LinearLayout>
</ScrollView>
