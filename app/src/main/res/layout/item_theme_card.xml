<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="24dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:id="@+id/themeBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="32dp">

        <TextView
            android:id="@+id/tvThemeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stark White"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:layout_alignParentTop="true"/>

        <TextView
            android:id="@+id/tvThemeDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvThemeName"
            android:layout_marginTop="8dp"
            android:text="Pure monochrome precision."
            android:textColor="#80FFFFFF"
            android:fontFamily="sans-serif-light"/>

        <ImageView
            android:id="@+id/ivThemePreview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_centerInParent="true"
            android:scaleType="centerInside"
            app:tint="#FFFFFF"
            android:src="@android:drawable/ic_menu_gallery"/>

        <Button
            android:id="@+id/btnApplyTheme"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_alignParentBottom="true"
            android:text="Apply Theme"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            app:cornerRadius="28dp"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
