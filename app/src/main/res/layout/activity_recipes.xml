<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <TextView
        android:id="@+id/tvRecipesTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHEF AI"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:fontFamily="sans-serif-light"
        android:layout_margin="24dp"
        android:letterSpacing="0.2"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatRecipes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvRecipesTitle"
        android:layout_above="@id/inputContainerRecipes"
        android:padding="16dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:id="@+id/inputContainerRecipes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="16dp"
        android:background="#11FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/etMessageInputRecipes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ask for a recipe or meal plan..."
                android:textColorHint="#8E8E93"
                android:textColor="#FFFFFF"
                android:background="@android:color/transparent"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp"
                android:maxLines="4"
                android:fontFamily="sans-serif-light"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnSendRecipes"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_send"
                android:padding="12dp"
                app:tint="#000000"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</RelativeLayout>
