<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvLoginHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:fontFamily="sans-serif-black"
            android:text="ACCESS\nPROTOCOL"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:letterSpacing="-0.03"
            android:lineSpacingMultiplier="0.9"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Authenticate to synchronize with Aura."
            android:textColor="#8E8E93"
            android:textSize="16sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="48dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="Email Address"
                    android:inputType="textEmailAddress"
                    android:padding="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#48484A"
                    android:fontFamily="sans-serif-light"/>

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#22FFFFFF" android:layout_marginHorizontal="8dp"/>

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="Security Password"
                    android:inputType="textPassword"
                    android:padding="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#48484A"
                    android:fontFamily="sans-serif-light"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="#FFFFFF"
            android:text="Authenticate"
            android:textColor="#000000"
            android:fontFamily="sans-serif-medium"
            android:textSize="17sp"
            android:textAllCaps="false"
            app:cornerRadius="32dp" />

        <TextView
            android:id="@+id/tvSignupRedirect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Create New Evolution"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GLIMMER SECURITY PROTOCOL v1.0"
            android:textColor="#1C1C1E"
            android:textSize="10sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
